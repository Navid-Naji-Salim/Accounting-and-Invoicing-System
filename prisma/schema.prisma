generator client {
  provider = "prisma-client"
  output   = "../backend/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id          String   @id @default(cuid())
  name        String
  sku         String?  @unique
  description String?
  unitCost    Decimal  @db.Decimal(12, 2)
  salesPrice  Decimal  @db.Decimal(12, 2)
  quantity    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id          String   @id @default(cuid())
  displayName String
  companyName String?
  email       String?
  phone       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vendor {
  id          String   @id @default(cuid())
  displayName String
  companyName String?
  email       String?
  phone       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Administrator")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
