generator client {
  provider = "prisma-client"
  output   = "../backend/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id                String   @id @default(cuid())
  name              String
  sku               String?  @unique
  itemType          String   @default("goods")
  unit              String?
  imageUrl          String?
  description       String?
  salesEnabled      Boolean  @default(true)
  salesPrice        Decimal  @db.Decimal(12, 2)
  salesAccount      String   @default("Sales")
  salesTax          String?
  salesDescription  String?
  purchaseEnabled   Boolean  @default(true)
  unitCost          Decimal  @db.Decimal(12, 2)
  purchaseAccount   String   @default("Cost of Goods Sold")
  purchaseTax       String?
  purchaseDescription String?
  preferredVendorId String?
  preferredVendor   Vendor?  @relation(fields: [preferredVendorId], references: [id], onDelete: SetNull)
  quantity          Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Customer {
  id          String   @id @default(cuid())
  displayName String
  companyName String?
  email       String?
  phone       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vendor {
  id          String   @id @default(cuid())
  displayName String
  companyName String?
  email       String?
  phone       String?
  notes       String?
  items       Item[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Administrator")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
